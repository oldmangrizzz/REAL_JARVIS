#!/bin/bash
# Pre-commit hook: refuse to commit secrets
# Install: git config core.hooksPath .githooks

set -e

# Colors for output
RED='\033[0;31m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

SECRETS_FOUND=0

# Check staged files
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null || true)

# Patterns to reject
REJECT_PATTERNS=(
    "\.env$"
    "\.jarvis/voice-bridge\.env$"
    "\.jarvis/secrets/.*\.env$"
    "changeme-jarvis-secret-2024"
    "215e04004290932b4fe76c83a8e6a1e75e0ec0af541c756c"
    'v\$G6a!k7\^\@TE@7U&bXEk'
)

# Check each staged file
while IFS= read -r file; do
    [ -z "$file" ] && continue
    
    # Skip deleted files
    if ! git cat-file -e :0:"$file" 2>/dev/null; then
        continue
    fi
    
    # Check file content against patterns
    for pattern in "${REJECT_PATTERNS[@]}"; do
        if git show ":0:$file" 2>/dev/null | grep -qE "$pattern"; then
            echo -e "${RED}✗ Secret pattern detected in: $file${NC}"
            echo "  Pattern: $pattern"
            SECRETS_FOUND=1
        fi
    done
    
    # Extra check for filenames themselves
    if [[ "$file" =~ \.env$ ]] && [[ ! "$file" =~ \.env\.example$ ]]; then
        echo -e "${RED}✗ Secret file in staging: $file${NC}"
        SECRETS_FOUND=1
    fi
done <<< "$STAGED_FILES"

if [ $SECRETS_FOUND -eq 1 ]; then
    echo ""
    echo -e "${YELLOW}Commit blocked: secrets detected.${NC}"
    echo "If you need to store secrets, use .env (which is in .gitignore)."
    echo "If you meant to add a template, use .env.example with <ROTATE_ME> placeholders."
    exit 1
fi

exit 0
