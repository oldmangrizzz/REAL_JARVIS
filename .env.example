# JARVIS Runtime Environment Variables
# Copy to .env and fill in actual values — DO NOT COMMIT .env to git
# 
# This file is a TEMPLATE. Every value should be replaced with actual credentials
# before runtime. Treat the actual .env file with the same care as SSH private keys.

# Voice/TTS Configuration
JARVIS_CANON_TTS_HOST=delta.grizzlymedicine.icu
JARVIS_CANON_TTS_PORT=8787
JARVIS_TTS_BEARER=<ROTATE_ME>
JARVIS_DELTA_HOST=delta.grizzlymedicine.icu

# Voice Bridge
JARVIS_VOICE_BRIDGE_SECRET=<ROTATE_ME>

# Control Plane
JARVIS_CONTROL_HOST=<ROTATE_ME>
JARVIS_HOMEBRIDGE_PORT=<ROTATE_ME>
JARVIS_COUCH_PORT=<ROTATE_ME>
JARVIS_HOST_ADDR=<ROTATE_ME>
JARVIS_HOST_PORT=<ROTATE_ME>
JARVIS_NODE_ROLE=<ROTATE_ME>
JARVIS_REPO_ROOT=/Users/grizzmed/REAL_JARVIS
JARVIS_LOG_LEVEL=info
JARVIS_TUNNEL_SECRET=<ROTATE_ME>
JARVIS_COUCHDB_PASSPHRASE=<ROTATE_ME>

# Convex Backend
JARVIS_CONVEX_URL=<ROTATE_ME>
JARVIS_CONVEX_AUTH_TOKEN=<ROTATE_ME>
CONVEX_URL=<ROTATE_ME>

# Mesh Display
MESH_DISPLAY_SECRET=<ROTATE_ME>
JARVIS_DISPLAY_ALLOWED_HOSTS=grizzlymedicine.icu,*.grizzlymedicine.icu

# n8n Workflows
N8N_API_KEY=<ROTATE_ME>
N8N_BASE_URL=<ROTATE_ME>
N8N_WEBHOOK_BASE=<ROTATE_ME>

# PWA / WebSocket Proxy
SHARED_SECRET=<ROTATE_ME>

# Letta (Memory Backend)
JARVIS_LETTA_EXCLUSIVE=true

# Node Credentials (SSH Access)
# Note: These should ideally be managed via SSH keys, not env vars
# If env vars are required, rotate regularly
ALPHA_HOST=192.168.4.100
BETA_HOST=192.168.4.151
CHARLIE_HOST=76.13.146.61
DELTA_HOST=187.124.28.147
FOXTROT_HOST=192.168.4.152
ECHO_HOST=192.168.7.114

# GitHub / OAuth
GITHUB_TOKEN=<ROTATE_ME>
GITHUB_PAT=<ROTATE_ME>

# Mapbox
MAPBOX_ACCESS_TOKEN=<ROTATE_ME>

# HuggingFace (for embeddings, models)
HUGGINGFACE_TOKEN=<ROTATE_ME>

# Google Cloud / Workspace
GOOGLE_CLOUD_KEY=<ROTATE_ME>
GOOGLE_WORKSPACE_KEY=<ROTATE_ME>

# Apple ID
APPLE_ID=<ROTATE_ME>
APPLE_PASSWORD=<ROTATE_ME>

# Logging/Telemetry
JARVIS_TELEMETRY_ENABLED=true
JARVIS_ALIGNMENT_TAX_DIR=.jarvis/alignment_tax

# Optional: Feature flags
CANON_SIG_ENFORCE=false
